---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
---

<Layout titre="Contact">
    <section class="max-w-6xl mx-auto px-4 py-10">
        <div class="rounded-2xl border border-black bg-fuchsia-100 p-8 md:p-12">
            <p
                class="text-sm font-semibold uppercase tracking-wide text-gray-700 mb-3"
            >
                Contact
            </p>
            <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-4">
                Parlons de votre projet immobilier
            </h1>
            <p class="text-gray-700 text-base md:text-lg max-w-3xl">
                Une question sur une offre, un agent ou une demande d'estimation
                ? Envoyez-nous un message et nous vous répondons rapidement.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-8">
            <article class="rounded-xl border border-gray-300 bg-white p-5">
                <h2 class="text-lg font-semibold mb-2">Adresse</h2>
                <p class="text-sm text-gray-700">Montbéliard, France</p>
            </article>

            <article class="rounded-xl border border-gray-300 bg-white p-5">
                <h2 class="text-lg font-semibold mb-2">Email</h2>
                <p class="text-sm text-gray-700">contact@leilahousing.fr</p>
            </article>

            <article class="rounded-xl border border-gray-300 bg-white p-5">
                <h2 class="text-lg font-semibold mb-2">Téléphone</h2>
                <p class="text-sm text-gray-700">+33 6 00 00 00 00</p>
            </article>
        </div>

        <div class="mt-8 rounded-xl border border-gray-300 bg-white p-6">
            <h2 class="text-2xl font-bold mb-4">Envoyer un message</h2>

            <form class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <input
                    type="text"
                    name="nom"
                    placeholder="Votre nom"
                    required
                    class="w-full p-2 border border-gray-300 rounded-md"
                />
                <input
                    type="email"
                    name="email"
                    placeholder="Votre email"
                    required
                    class="w-full p-2 border border-gray-300 rounded-md"
                />
                <input
                    type="text"
                    name="sujet"
                    placeholder="Sujet"
                    required
                    class="w-full p-2 border border-gray-300 rounded-md md:col-span-2"
                />
                <textarea
                    name="message"
                    rows="5"
                    placeholder="Votre message"
                    required
                    class="w-full p-2 border border-gray-300 rounded-md md:col-span-2"
                ></textarea>

                <button
                    type="submit"
                    class="md:col-span-2 bg-fuchsia-100 hover:bg-fuchsia-200 rounded-lg text-black p-2 border border-black transition-colors"
                >
                    Envoyer
                </button>
            </form>
        </div>
    </section>
</Layout>
