---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card.astro";

import { getOffres } from "../../js/backend.mjs";
const offres = await getOffres();
---

<Layout titre="Offres">
    <h1>Offres</h1>

    <div class="filters mb-6 flex flex-wrap gap-2">
        <button
            id="favori-button"
            class="bg-fuchsia-100 hover:bg-fuchsia-200 rounded-lg text-black p-2 border border-black transition-colors"
        >
            Afficher les favoris
        </button>
        <a
            href="/offres/surface/80"
            class="bg-blue-100 hover:bg-blue-200 rounded-lg text-black p-2 border border-black transition-colors"
        >
            Maisons > 80m²
        </a>
        <a
            href="/offres/prix/300000"
            class="bg-green-100 hover:bg-green-200 rounded-lg text-black p-2 border border-black transition-colors"
        >
            Maisons &lt; 300k€
        </a>
        <a
            href="/offres/prix/200000-400000"
            class="bg-yellow-100 hover:bg-yellow-200 rounded-lg text-black p-2 border border-black transition-colors"
        >
            Maisons 200k-400k€
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
            offres.map((offre) => (
                <div
                    class="offre bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow"
                    data-favori={offre.favori ? "true" : "false"}
                >
                    <Card offre={offre} />
                </div>
            ))
        }
    </div>
</Layout>

<style>
    .offre {
        border: 1px solid #e5e7eb;
    }

    .offre[data-favori="true"] {
        border-color: #10b981;
        background-color: #ecfdf5;
    }
</style>

<script>
    //@ts-nocheck
    const button = document.getElementById("favori-button");
    let showOnlyFavorites = false;

    button?.addEventListener("click", () => {
        showOnlyFavorites = !showOnlyFavorites;
        const offres = document.querySelectorAll(".offre");

        offres.forEach((offre) => {
            const isFavori = offre.dataset.favori === "true";

            if (showOnlyFavorites) {
                offre.style.display = isFavori ? "block" : "none";
                button.textContent = "Afficher tout";
            } else {
                offre.style.display = "block";
                button.textContent = "Afficher les favoris";
            }

            if (offre.dataset.favori === "true") {
                offre.classList.add("bg-green-300");
            } else {
                offre.classList.add("bg-white");
            }
        });
    });
</script>
