---
import { getImageUrl } from "../js/backend.mjs";
const { record, imageField, width = 400, height = 300 } = Astro.props;
const imageURL = await getImageUrl(record, imageField);
---

{
    imageURL && (
        <Image
            src={imageURL}
            alt={record.nomMaison || "image"}
            width={width}
            height={height}
            inferSize={false}
        />
    )
}
